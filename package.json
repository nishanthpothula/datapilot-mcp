{
  "name": "datapilot-mcp",
  "version": "1.0.0",
  "description": "Enterprise-grade Data & Analytics MCP Server with Auth0 OIDC, LangSmith tracing, and 12 tools across 4 skills",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/stdio.js",
    "dev": "tsx watch src/index.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "seed": "tsx src/db/seed.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@auth0/nextjs-auth0": "^3.5.0",
    "express": "^4.19.2",
    "better-sqlite3": "^9.6.0",
    "jose": "^5.3.0",
    "langsmith": "^0.1.56",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.1",
    "ajv": "^8.17.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.5",
    "papaparse": "^5.4.1",
    "json2csv": "^6.0.0-alpha.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^10.0.0",
    "@types/node": "^20.14.9",
    "@types/papaparse": "^5.3.14",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
